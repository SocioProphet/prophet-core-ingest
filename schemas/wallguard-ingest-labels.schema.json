{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/prophet-core-ingest/wallguard-ingest-labels.schema.json",
  "title": "WallGuard Ingest Labels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "ingest_id",
    "source_ref",
    "source_provenance_ref",
    "client_ref",
    "matter_ref",
    "workroom_ref",
    "wall_ref",
    "classification",
    "label_state",
    "clean_room_eligible",
    "permitted_destination_refs",
    "permitted_subject_refs",
    "policy_refs",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "record_type": {"const": "WallGuardIngestLabels"},
    "ingest_id": {"type": "string", "minLength": 1},
    "source_ref": {"type": "string", "minLength": 1},
    "source_provenance_ref": {"type": "string", "minLength": 1},
    "client_ref": {"type": "string", "minLength": 1},
    "matter_ref": {"type": "string", "minLength": 1},
    "workroom_ref": {"type": "string", "minLength": 1},
    "wall_ref": {"type": "string", "minLength": 1},
    "classification": {"enum": ["public", "firm_approved", "client_confidential", "matter_restricted", "wall_restricted", "clean_room_derived"]},
    "label_state": {"enum": ["complete", "quarantined", "reclassified"]},
    "clean_room_eligible": {"type": "boolean"},
    "permitted_destination_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "permitted_subject_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "policy_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "quarantine_reason": {"type": "string"}
  }
}
